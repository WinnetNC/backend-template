{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "rootDir": "./src",
    "outDir": "./dist",

    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    },

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck":  true,
    "verbatimModuleSyntax": false
    },
    "include": ["src"],     
    "exclude": ["node_modules", "dist"]
  
}